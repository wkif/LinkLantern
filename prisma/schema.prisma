// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户模型 - 包含基本认证功能
model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique @db.VarChar(255)
  password              String    @db.VarChar(255)              // 加密后的密码
  name                  String?   @db.VarChar(255)
  avatar                String?   @db.VarChar(500)              // 头像 URL
  homeBackground        String?   @db.LongText                  // 首页背景图片（base64）
  useBingWallpaper      Boolean   @default(false)               // 是否启用必应壁纸
  backgroundOpacity     Int       @default(80)                  // 背景遮罩透明度 (0-100)
  backgroundBlur        Int       @default(8)                   // 背景模糊度 (0-20)
  isActive              Boolean   @default(true)                // 账户是否激活
  emailVerified         Boolean   @default(false)               // 邮箱是否验证
  lastLoginAt           DateTime?                               // 最后登录时间
  bookmarkToken         String?   @unique @db.VarChar(64)        // 浏览器扩展快捷收藏令牌（明文，可轮换）
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // 关联：用户可以有多个收藏链接
  links                 Link[]

  // 关联：用户可以有多个 AI 配置
  aiConfigs             AiConfig[]

  // 关联：AI 对话话题
  aiConversations       AiConversation[]

  @@index([email])
}

// 链接模型 - 用户收藏的网站链接
model Link {
  id          Int      @id @default(autoincrement())
  url         String   @db.VarChar(1000)               // 链接地址
  title       String   @db.VarChar(255)                // 网站标题
  description String?  @db.Text                        // 描述（可选）
  icon        String?  @db.Text                        // 图标 (base64 或 URL)
  category    String?  @db.VarChar(100)                // 分类（可选）
  isPublic    Boolean  @default(false)                 // 是否公开
  clicks      Int      @default(0)                     // 点击次数
  userId      Int                                      // 所属用户ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // 关联到用户
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

// AI 配置模型 - 用户可以配置多个 AI 终端
model AiConfig {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)                  // 配置名称 (如 "GPT-4", "Claude")
  apiKey        String    @db.VarChar(500)                  // OpenAI API 密钥
  baseUrl       String    @default("https://api.openai.com/v1") @db.VarChar(500)  // API 基础 URL
  model         String    @default("gpt-4o") @db.VarChar(100) // 模型名称
  maxTokens     Int       @default(4096)                     // 最大令牌数
  temperature   Float     @default(0.7)                      // 温度参数
  isActive      Boolean   @default(false)                    // 是否激活
  userId        Int                                      // 所属用户ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联到用户
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// AI 对话话题（会话）
model AiConversation {
  id        Int          @id @default(autoincrement())
  title     String       @default("新话题") @db.VarChar(200)
  userId    Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
}

// AI 对话单条消息
model AiMessage {
  id             Int             @id @default(autoincrement())
  conversationId Int
  role           String          @db.VarChar(20) // user | assistant
  content        String          @db.LongText
  createdAt      DateTime        @default(now())

  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}


